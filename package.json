{
  "name": "stockmaster",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx seed.ts",
    "test-db": "tsx scripts/test-connection.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "test-forgot-password": "tsx scripts/test-forgot-password.ts",
    "test-resend-email": "tsx scripts/test-resend-email.ts",
    "routes:collect": "tsx --no-cache scripts/collect-routes.ts",
