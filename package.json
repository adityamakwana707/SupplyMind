    "routes:test": "tsx --no-cache scripts/route-smoke-test.ts",
    "routes:test:mutations": "set RUN_MUTATION_TESTS=true&& tsx --no-cache scripts/route-smoke-test.ts",
    "functionality:test": "tsx --no-cache scripts/functionality-smoke-test.ts",
    "functionality:test:mutations": "set RUN_MUTATION_TESTS=true&& tsx --no-cache scripts/functionality-smoke-test.ts",
    "test:platform": "npm run routes:collect && npm run routes:test && npm run functionality:test",
    "test:roles": "tsx --no-cache scripts/role-feature-test.ts",
    "test:roles:mutations": "set RUN_ROLE_MUTATIONS=true&& tsx --no-cache scripts/role-feature-test.ts",
    "test:e2e:verbose": "set DEBUG=1&& tsx --no-cache scripts/e2e-test.ts"
  },
