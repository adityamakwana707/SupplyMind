    "firebase-admin": "^10.3.0",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.294.0",
    "motion": "^12.23.24",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
